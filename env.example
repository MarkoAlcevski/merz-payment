# ============================================================
#  Merdz Sky Wellness — booking system environment variables
# ============================================================
# Copy the values you have into the Netlify dashboard:
#   Site settings → Environment variables.
# Do NOT commit a filled-in .env to git. This .env.example only
# documents the variable NAMES — it contains no real secrets.
#
# EVERYTHING is optional for DEMO MODE. With nothing set, the whole
# booking flow runs as a clearly-labelled simulation (no real DB,
# no real payments, no real emails). Add credentials to switch each
# subsystem from demo to live, independently.

# ------------------------------------------------------------
#  Database (Supabase / PostgreSQL)
# ------------------------------------------------------------
# Without these, the app uses an in-memory demo store (per-container,
# NOT persistent — see BOOKING_SETUP.md). With them, data is stored
# in your Supabase project. The SERVICE ROLE key bypasses RLS and must
# only ever live on the server (Netlify env), never in frontend code.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# ------------------------------------------------------------
#  Admin panel authentication
# ------------------------------------------------------------
# Required to use the real admin panel. If unset, admin runs in demo
# mode with the password "demo" (clearly labelled).
ADMIN_PASSWORD=
# Optional: secret used to sign admin session tokens. If unset, a value
# derived from ADMIN_PASSWORD is used. Set a long random string for production.
ADMIN_SESSION_SECRET=

# ------------------------------------------------------------
#  PayPal (official Checkout v2 REST API)
# ------------------------------------------------------------
# Without CLIENT_ID + CLIENT_SECRET, PayPal runs in demo mode
# (simulated approval, no money moves). CLIENT_ID is public (sent to
# the browser); the SECRET is server-only and never exposed.
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_ENVIRONMENT=sandbox        # sandbox | live
PAYPAL_CURRENCY=EUR

# ------------------------------------------------------------
#  NLB Banka card gateway
# ------------------------------------------------------------
# Real card payments require an approved NLB e-commerce merchant
# account and NLB's official integration spec. Until you have those,
# keep NLB_MODE=test for a simulated bank redirect. See BOOKING_SETUP.md
# (NLB) and netlify/functions/lib/nlb.js for the EXACT place to plug in
# the official merchant parameters & signature algorithm.
NLB_MODE=test                     # test | live
NLB_MERCHANT_ID=
NLB_TERMINAL_ID=
NLB_SECRET_KEY=
NLB_PAYMENT_URL=                  # official NLB gateway URL (from merchant docs)
NLB_SUCCESS_URL=                  # e.g. https://yoursite.com/booking-result.html?provider=nlb&result=success
NLB_FAILURE_URL=                  # e.g. https://yoursite.com/booking-result.html?provider=nlb&result=failure
NLB_CANCEL_URL=                   # e.g. https://yoursite.com/booking-result.html?provider=nlb&result=cancel
NLB_CALLBACK_URL=                 # e.g. https://yoursite.com/api/nlb-callback  (server-to-server)
NLB_CURRENCY=EUR

# ------------------------------------------------------------
#  Email confirmations (Resend)
# ------------------------------------------------------------
# Without RESEND_API_KEY, emails are NOT sent — the payload is logged
# (server) and returned in API responses in demo mode for inspection.
RESEND_API_KEY=
EMAIL_FROM="Merdz Sky Wellness <bookings@yourdomain.com>"
OWNER_EMAIL=                      # where owner copies of bookings are sent

# ------------------------------------------------------------
#  General
# ------------------------------------------------------------
# Public base URL of the deployed site (used to build payment return
# URLs). On Netlify this is provided automatically as URL/DEPLOY_URL,
# but you can override it here.
SITE_URL=
# Comma-separated list of allowed CORS origins for the API. Defaults to
# same-origin (the deployed site). Leave empty unless you call the API
# from another domain.
ALLOWED_ORIGINS=
